{
  "name": "hearcare-shop",
  "version": "1.0.0",
  "description": "Hearing Aid Shop Tycoon — 2D Canvas Game",
  "scripts": {
    "dev": "bun run build:dev && bun server.ts",
    "build": "bun build src/main.ts --outfile dist/bundle.js --target browser --minify-whitespace",
    "build:dev": "bun build src/main.ts --outfile dist/bundle.js --target browser --sourcemap=inline",
    "serve": "bun server.ts",
    "watch": "bun build src/main.ts --outfile dist/bundle.js --target browser --sourcemap=inline --watch"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "dexie": "^4.4.2"
  }
}
